{
  "$schema": "https://developers.reddit.com/schema/config-file.v1.json",
  "name": "resonance-pad",
  "dev": {
    "subreddit": "resonance_pad_dev"
  },
  "post": {
    "dir": "dist/client",
    "entrypoints": {
      "default": {
        "inline": true,
        "entry": "game.html"
      },
      "game": {
        "entry": "game.html"
      }
    }
  },
  "server": {
    "dir": "dist/server",
    "entry": "index.cjs"
  },
  "permissions": {
    "realtime": true,
    "redis": true,
    "reddit": {
      "enable": true,
      "scope": "moderator"
    }
  },
  "menu": {
    "items": [
      {
        "label": "Create a new post",
        "description": "Start today's RESONANCE jam",
        "location": "subreddit",
        "forUserType": "moderator",
        "endpoint": "/internal/menu/post-create"
      }
    ]
  },
  "triggers": {
    "onAppInstall": "/internal/triggers/on-app-install"
  },
  "scheduler": {
    "tasks": {
      "daily-post": {
        "endpoint": "/internal/scheduler/daily-post",
        "cron": "0 12 * * *"
      }
    }
  },
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch"
  }
}
